# Copy to .env and fill in. NEVER commit .env.

# --- Claude (client pays on their own key) ---
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-haiku-4-5

# --- Per-client branding ---
BUSINESS_NAME=The Conduction Company
OWNER_NAME=the TCCO team
BOT_NAME=Dan
KNOWLEDGE_FILE=knowledge/tcco.md

# --- Where leads land (the client's call — fill from intake) ---
LEAD_EMAIL_TO=bryce@leckelectrical.co.nz
LEAD_SMS_TO=+64...                    # optional; leave blank to disable SMS
EMAIL_FROM=leads@tcco.co.nz           # the "from" address leads are sent from (verify in Resend)

# --- Email sending: Resend (recommended — just an API key) ---
# Sign up at resend.com, verify a sending domain, paste the key. That's it.
RESEND_API_KEY=

# --- Email sending: SMTP (fallback, only if not using Resend) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- SMS sending (Twilio, optional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+64...

# --- Web embed security ---
# Comma-separated origins allowed to call /chat (the client's website).
ALLOWED_ORIGINS=https://leckelectrical.co.nz,https://www.leckelectrical.co.nz
